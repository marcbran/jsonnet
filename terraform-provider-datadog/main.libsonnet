      }),
      dashboard_lists: resource.field('dashboard_lists'),
      dashboard_lists_removed: resource.field('dashboard_lists_removed'),
      description: resource.field('description'),
      id: resource.field('id'),
      is_read_only: resource.field('is_read_only'),
      layout_type: resource.field('layout_type'),
      notify_list: resource.field('notify_list'),
      reflow_type: resource.field('reflow_type'),
      restricted_roles: resource.field('restricted_roles'),
      tags: resource.field('tags'),
      title: resource.field('title'),
      url: resource.field('url'),
    },
    dashboard_json(name, block): {
      local resource = blockType.resource('datadog_dashboard_json', name),
      _: resource._(block, {
        dashboard: build.template(block.dashboard),
        dashboard_lists: build.template(std.get(block, 'dashboard_lists', null)),
